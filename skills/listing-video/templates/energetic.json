{
  "name": "energetic",
  "description": "Fast cuts, bold text, upbeat music — for social media impact",
  "video": {
    "default_duration": 25,
    "clip_durations": {
      "hero": 3,
      "standard": 2,
      "cta": 3
    },
    "transitions": {
      "into_ai_clip": {"type": "cut", "duration": 0},
      "out_of_ai_clip": {"type": "crossfade", "duration": 0.3},
      "between_slides": {"type": "crossfade", "duration": 0.3},
      "into_cta": {"type": "fade_black", "duration": 0.4}
    },
    "ken_burns": {
      "zoom_range": [1.0, 1.2],
      "preferred_motions": ["slow_push", "slide_left", "slide_right"]
    }
  },
  "text": {
    "font_family": "Montserrat-Bold",
    "title_size": 64,
    "subtitle_size": 40,
    "color": "#FFFFFF",
    "shadow": true,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "position": "bottom_center",
    "animation": "fade_up"
  },
  "music": {
    "style": "modern_upbeat",
    "bpm_range": [110, 130],
    "volume": 0.12,
    "fade_in": 0.5,
    "fade_out": 1.5,
    "duck_under_voice": true
  },
  "cta": {
    "bg_color": "#1a1a1a",
    "text_color": "#FFFFFF",
    "accent_color": "#FF6B35",
    "tagline_size": 56,
    "name_size": 48,
    "phone_size": 40
  }
}
