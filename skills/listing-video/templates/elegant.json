{
  "name": "elegant",
  "description": "Slow transitions, serif fonts, piano music — for luxury listings",
  "video": {
    "default_duration": 35,
    "clip_durations": {
      "hero": 4,
      "standard": 3,
      "cta": 5
    },
    "transitions": {
      "into_ai_clip": {"type": "crossfade", "duration": 0.8},
      "out_of_ai_clip": {"type": "crossfade", "duration": 0.8},
      "between_slides": {"type": "crossfade", "duration": 0.6},
      "into_cta": {"type": "fade_black", "duration": 1.0}
    },
    "ken_burns": {
      "zoom_range": [1.0, 1.1],
      "preferred_motions": ["slow_push", "pull_back"]
    }
  },
  "text": {
    "font_family": "Playfair-Display",
    "title_size": 56,
    "subtitle_size": 36,
    "color": "#FFFFFF",
    "shadow": true,
    "shadow_color": "#000000",
    "shadow_opacity": 0.5,
    "position": "bottom_center",
    "animation": "fade"
  },
  "music": {
    "style": "piano_ambient",
    "bpm_range": [60, 90],
    "volume": 0.10,
    "fade_in": 1.0,
    "fade_out": 2.5,
    "duck_under_voice": true
  },
  "cta": {
    "bg_color": "#0d0d0d",
    "text_color": "#E8D5B7",
    "accent_color": "#C9A96E",
    "tagline_size": 52,
    "name_size": 44,
    "phone_size": 36
  }
}
