# Required
ANTHROPIC_API_KEY=your-anthropic-api-key

# IMA Studio (primary: video generation + TTS)
IMA_API_KEY=your-ima-api-key
IMA_APP_ID=your-ima-app-id
IMA_APP_KEY=your-ima-app-key
# IMA_VIDEO_MODEL=kling          # optional: kling, wan2.6, hailuo, vidu, pixverse
# IMA_TTS_MODEL=speech-02-hd     # optional: speech-02-hd, seed-tts

# Optional fallbacks (used when IMA is unavailable)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_VOICE_ID=                # optional: override all style-based voice selection
OPENAI_API_KEY=your-openai-api-key

# OpenClaw ↔ Reel Agent auth (recommended for any non-local deployment)
REEL_AGENT_TOKEN=replace-with-shared-bearer-token
ADMIN_TOKEN=replace-with-admin-token
REEL_AGENT_URL=http://127.0.0.1:8000
OPENCLAW_CALLBACK_BASE_URL=http://127.0.0.1:18789/reel-agent
OPENCLAW_CALLBACK_SECRET=replace-with-shared-callback-secret

# Market Data (Daily Insight — free, get key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your-fred-api-key

# Daily Insight schedule (optional — default 13:00 UTC = 8:00 AM US Eastern)
# DAILY_INSIGHT_HOUR_UTC=13

# Quality & cost limits (optional — sensible defaults built in)
# DELIVERY_BLOCK_THRESHOLD=4.0      # Block delivery if score < this (0-10)
# AUTO_RETRY_THRESHOLD=4.0          # Auto-retry if review score < this
# JOB_COST_LIMIT_CREDIT=200         # Stop auto-retry if IMA credits exceed this

# Performance tuning (optional)
# RENDER_MAX_WORKERS=6               # Max parallel video render threads
# TTS_MAX_WORKERS=4                  # Max parallel TTS calls
# CALLBACK_MAX_ATTEMPTS=10           # Max callback retry attempts before dead letter
# CLEANUP_FAILED_DAYS=7              # Days to keep FAILED job artifacts
# CLEANUP_DELIVERED_DAYS=30          # Days to keep DELIVERED job artifacts
